---
const {
	title,
	temperature,
	icon = null,
} = Astro.props;
---

<div class="flex items-center flex-1 justify-center">
	<img
		src=`https://openweathermap.org/img/wn/${icon}@4x.png`
		alt=""
		class="size-24 weekly-icon-shadow -mr-2"
	/>
	<div class="flex flex-col items-start">
		<span class="font-mono text-sm weekly-label uppercase tracking-wider leading-none">{title}</span>
		<span class="font-mono text-3xl font-bold weekly-temp leading-tight">{temperature}°</span>
	</div>
</div>
