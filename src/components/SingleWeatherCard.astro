---
const {
	title,
	temperature,
	icon = null,
} = Astro.props;
---

<div class="flex items-center flex-1 justify-center">
	<img
		src=`https://openweathermap.org/img/wn/${icon}@4x.png`
		alt=""
		class="w-14 h-14 weekly-icon-shadow"
	/>
	<div class="flex flex-col items-start">
		<span class="font-mono text-xs weekly-label uppercase tracking-wider leading-none">{title}</span>
		<span class="font-mono text-2xl font-bold weekly-temp leading-tight">{temperature}°</span>
	</div>
</div>
