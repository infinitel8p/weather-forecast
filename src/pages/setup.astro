				<g class="sg-label" font-size="4.5" text-anchor="middle">
					<text x="228" y="17">30°</text>
					<text x="384" y="175" text-anchor="end">60°</text>
					<text x="384" y="230" text-anchor="end">120°</text>
					<text x="228" y="393">150°</text>
					<text x="172" y="393">210°</text>
					<text x="14" y="230">240°</text>
					<text x="14" y="175">300°</text>
					<text x="172" y="17">330°</text>
				</g>

				<!-- Cardinal labels -->
				<text x="200" y="8" text-anchor="middle" class="svg-cardinal" font-size="7">N</text>
				<text x="396" y="203" text-anchor="end" class="svg-cardinal" font-size="7">E</text>
				<text x="200" y="398" text-anchor="middle" class="svg-cardinal" font-size="7">S</text>
				<text x="2" y="203" text-anchor="start" class="svg-cardinal" font-size="7">W</text>

				<!-- Range labels -->
				<text x="200" y="157" text-anchor="middle" class="svg-range-label" font-size="5">50km</text>
				<text x="200" y="112" text-anchor="middle" class="svg-range-label" font-size="5">100km</text>

				<!-- Angle indicator at center -->
				<path d="M 218 200 A 18 18 0 0 0 213 183" fill="none" class="sg-angle-arc" stroke-width="0.4"/>
				<text x="222" y="190" class="sg-label" font-size="3.5">23.4°</text>

