		}
		#setup-main[data-theme="day-hc"] .setup-panel {
			background: linear-gradient(180deg, #e8e1d5, #e3dace);
			border-color: rgba(var(--accent-copper), 0.16);
			box-shadow: -1px 0 12px rgba(var(--accent), 0.07);
		}
		#setup-main[data-theme="day-hc"] .svg-cardinal { fill: rgba(var(--accent-copper), 0.65); }
		#setup-main[data-theme="day-hc"] .svg-range-label { fill: rgba(var(--accent-copper), 0.5); }
		#setup-main[data-theme="day-hc"] .svg-tick-major { stroke: rgba(var(--accent-copper), 0.5); }
		#setup-main[data-theme="day-hc"] .svg-tick-minor { stroke: rgba(var(--accent), 0.3); }
		#setup-main[data-theme="day-hc"] .svg-ring { stroke: rgba(var(--accent-copper), 0.3); }
		#setup-main[data-theme="day-hc"] .svg-ring-mid { stroke: rgba(var(--accent-copper), 0.25); }
		#setup-main[data-theme="day-hc"] .svg-ring-far { stroke: rgba(var(--accent), 0.2); }
		#setup-main[data-theme="day-hc"] .svg-ring-outer { stroke: rgba(var(--accent-copper), 0.18); }
		#setup-main[data-theme="day-hc"] .svg-crosshair { stroke: rgba(var(--accent-copper), 0.14); }
		#setup-main[data-theme="day-hc"] .svg-intersection { stroke: rgba(var(--accent-copper), 0.4); }

		/* Geometric elements — high contrast */
		#setup-main[data-theme="day-hc"] .sg-radial         { stroke: rgba(var(--accent), 0.08); }
		#setup-main[data-theme="day-hc"] .sg-ecliptic ellipse   { stroke: rgba(var(--accent-copper), 0.12); }
		#setup-main[data-theme="day-hc"] .sg-ecliptic circle    { stroke: rgba(var(--accent-copper), 0.16); }
		#setup-main[data-theme="day-hc"] .sg-tick-micro     { stroke: rgba(var(--accent-copper), 0.06); }
		#setup-main[data-theme="day-hc"] .sg-hexagon        { stroke: rgba(var(--accent-copper), 0.12); }
		#setup-main[data-theme="day-hc"] .sg-flower         { stroke: rgba(var(--accent-copper), 0.08); }
		#setup-main[data-theme="day-hc"] .sg-flower-center  { stroke: rgba(var(--accent-copper), 0.12); }
		#setup-main[data-theme="day-hc"] .sg-pentagon       { stroke: rgba(var(--accent-copper), 0.1);  }
		#setup-main[data-theme="day-hc"] .sg-star           { stroke: rgba(var(--accent-copper), 0.09); }
		#setup-main[data-theme="day-hc"] .sg-vesica         { stroke: rgba(var(--accent-copper), 0.12); }
		#setup-main[data-theme="day-hc"] .sg-spiral         { stroke: rgba(var(--accent-copper), 0.14); }
		#setup-main[data-theme="day-hc"] .sg-solar-ray line { stroke: rgba(var(--accent-warm), 0.08); }
		#setup-main[data-theme="day-hc"] .sg-solar-disk     { stroke: rgba(var(--accent-warm), 0.18); }
		#setup-main[data-theme="day-hc"] .sg-arc            { stroke: rgba(var(--accent-copper), 0.12); }
		#setup-main[data-theme="day-hc"] .sg-compass-rose path { stroke: rgba(var(--accent-copper), 0.14); }
		#setup-main[data-theme="day-hc"] .sg-prop-tick      { stroke: rgba(var(--accent-warm), 0.18); }
		#setup-main[data-theme="day-hc"] .sg-label          { fill: rgba(var(--accent-copper), 0.15); }
		#setup-main[data-theme="day-hc"] .sg-angle-arc      { stroke: rgba(var(--accent-copper), 0.13); }
		#setup-main[data-theme="day-hc"] .sg-wave-path      { stroke: rgba(var(--accent-copper), 0.1);  }
		#setup-main[data-theme="day-hc"] .sg-constellation circle { fill: rgba(var(--accent-warm), 0.16); }
		#setup-main[data-theme="day-hc"] .sg-constellation line   { stroke: rgba(var(--accent-warm), 0.1); }
		#setup-main[data-theme="day-hc"] .sg-meander path   { stroke: rgba(var(--accent-copper), 0.12); }
		#setup-main[data-theme="day-hc"] .sg-meander line   { stroke: rgba(var(--accent-copper), 0.08); }
		#setup-main[data-theme="day-hc"] .sg-corner         { stroke: rgba(var(--accent-copper), 0.14); }

		/* Footer link */
		#footer-link {
			text-shadow: 0 0 8px rgba(var(--accent), 0.08);
		}
		#footer-link:hover {
			color: rgba(var(--accent), 0.4);
			text-shadow: 0 0 6px rgba(var(--accent), 0.2), 0 0 15px rgba(var(--accent), 0.1);
		}
		#setup-main[data-theme^="day"] #footer-link {
			color: rgba(var(--accent-copper), 0.2);
		}
		#setup-main[data-theme^="day"] #footer-link:hover {
			color: rgba(var(--accent-warm), 0.55);
			text-shadow: 0 0 8px rgba(var(--accent-warm), 0.15);
		}

		/* ── Integrated geometric construction — Night mode ── */
		.sg-radial         { stroke: rgba(var(--accent), 0.03); }
		.sg-ecliptic ellipse   { stroke: rgba(var(--accent), 0.05); }
		.sg-ecliptic circle    { stroke: rgba(var(--accent), 0.07); }
		.sg-tick-micro     { stroke: rgba(var(--accent), 0.03); }

		.sg-hexagon        { stroke: rgba(var(--accent), 0.05); }
		.sg-flower         { stroke: rgba(var(--accent), 0.035); }
		.sg-flower-center  { stroke: rgba(var(--accent), 0.05); }
		.sg-pentagon       { stroke: rgba(var(--accent), 0.04); }
		.sg-star           { stroke: rgba(var(--accent), 0.04); }
		.sg-vesica         { stroke: rgba(var(--accent), 0.05); }
		.sg-spiral         { stroke: rgba(var(--accent), 0.06); }

		.sg-solar-ray line { stroke: rgba(var(--accent), 0.025); }
		.sg-solar-disk     { stroke: rgba(var(--accent), 0.08); }

		.sg-arc            { stroke: rgba(var(--accent), 0.05); }
		.sg-compass-rose path { stroke: rgba(var(--accent), 0.06); }
		.sg-prop-tick      { stroke: rgba(var(--accent), 0.08); }
		.sg-label          { fill: rgba(var(--accent), 0.06); }
		.sg-angle-arc      { stroke: rgba(var(--accent), 0.06); }

		.sg-wave-path      { stroke: rgba(var(--accent), 0.045); }

		.sg-constellation circle { fill: rgba(var(--accent), 0.08); stroke: none; }
		.sg-constellation line   { stroke: rgba(var(--accent), 0.04); }

		.sg-meander path   { stroke: rgba(var(--accent), 0.05); }
		.sg-meander line   { stroke: rgba(var(--accent), 0.035); }

		.sg-corner         { stroke: rgba(var(--accent), 0.06); }

		/* ── Integrated geometric construction — Day mode ── */
		#setup-main[data-theme^="day"] .sg-radial         { stroke: rgba(var(--accent), 0.05); }
		#setup-main[data-theme^="day"] .sg-ecliptic ellipse   { stroke: rgba(var(--accent-copper), 0.08); }
		#setup-main[data-theme^="day"] .sg-ecliptic circle    { stroke: rgba(var(--accent-copper), 0.11); }
		#setup-main[data-theme^="day"] .sg-tick-micro     { stroke: rgba(var(--accent-copper), 0.04); }

		#setup-main[data-theme^="day"] .sg-hexagon        { stroke: rgba(var(--accent-copper), 0.08); }
		#setup-main[data-theme^="day"] .sg-flower         { stroke: rgba(var(--accent-copper), 0.05); }
		#setup-main[data-theme^="day"] .sg-flower-center  { stroke: rgba(var(--accent-copper), 0.08); }
		#setup-main[data-theme^="day"] .sg-pentagon       { stroke: rgba(var(--accent-copper), 0.07); }
		#setup-main[data-theme^="day"] .sg-star           { stroke: rgba(var(--accent-copper), 0.06); }
		#setup-main[data-theme^="day"] .sg-vesica         { stroke: rgba(var(--accent-copper), 0.08); }
		#setup-main[data-theme^="day"] .sg-spiral         { stroke: rgba(var(--accent-copper), 0.09); }

		#setup-main[data-theme^="day"] .sg-solar-ray line { stroke: rgba(var(--accent-warm), 0.05); }
		#setup-main[data-theme^="day"] .sg-solar-disk     { stroke: rgba(var(--accent-warm), 0.12); }

		#setup-main[data-theme^="day"] .sg-arc            { stroke: rgba(var(--accent-copper), 0.08); }
		#setup-main[data-theme^="day"] .sg-compass-rose path { stroke: rgba(var(--accent-copper), 0.09); }
		#setup-main[data-theme^="day"] .sg-prop-tick      { stroke: rgba(var(--accent-warm), 0.12); }
		#setup-main[data-theme^="day"] .sg-label          { fill: rgba(var(--accent-copper), 0.1); }
		#setup-main[data-theme^="day"] .sg-angle-arc      { stroke: rgba(var(--accent-copper), 0.09); }

		#setup-main[data-theme^="day"] .sg-wave-path      { stroke: rgba(var(--accent-copper), 0.06); }

		#setup-main[data-theme^="day"] .sg-constellation circle { fill: rgba(var(--accent-warm), 0.1); }
		#setup-main[data-theme^="day"] .sg-constellation line   { stroke: rgba(var(--accent-warm), 0.06); }

		#setup-main[data-theme^="day"] .sg-meander path   { stroke: rgba(var(--accent-copper), 0.08); }
		#setup-main[data-theme^="day"] .sg-meander line   { stroke: rgba(var(--accent-copper), 0.05); }

		#setup-main[data-theme^="day"] .sg-corner         { stroke: rgba(var(--accent-copper), 0.09); }
	</style>

	<script>
		// ── Theme detection (day 06:00–21:59, night 22:00–05:59) ──
		// Append ?hc to the URL for high-contrast day mode (e.g. on Raspberry Pi)
		const main = document.getElementById("setup-main");
		const hour = new Date().getHours();
		const isDay = hour >= 6 && hour <= 21;
		const hc = new URLSearchParams(window.location.search).has("hc");
		const dayTheme = hc ? "day-hc" : "day";
		main.setAttribute("data-theme", isDay ? dayTheme : "night");

		// Accent RGB for JS-driven SVG attributes
		const accent = isDay ? (hc ? [90, 60, 18] : [110, 78, 30]) : [56, 189, 168];
		const accentAlt = isDay ? (hc ? [150, 75, 15] : [180, 95, 30]) : [45, 160, 200];
		// Warm highlight color for animated SVG elements in day mode
		const echoColor = isDay ? (hc ? [150, 90, 20] : [180, 120, 35]) : [56, 189, 168];

		// Update SVG gradient stops for current theme
		function applyGradientTheme() {
			const [er, eg, eb] = echoColor;
			const [ar, ag, ab] = accentAlt;
			const sweepA = isDay ? 0.28 : 0.45;
			const sweepB = isDay ? 0.04 : 0.03;
			const echoA = isDay ? 0.07 : 0.06;
			const echoB = isDay ? 0.05 : 0.04;

			document.getElementById("sweep-stop-0").setAttribute("stop-color", `rgba(${er},${eg},${eb},${sweepA})`);
			document.getElementById("sweep-stop-1").setAttribute("stop-color", `rgba(${er},${eg},${eb},${sweepB})`);

			document.getElementById("echo-stop-0").setAttribute("stop-color", `rgba(${er},${eg},${eb},0)`);
			document.getElementById("echo-stop-40").setAttribute("stop-color", `rgba(${er},${eg},${eb},0)`);
			document.getElementById("echo-stop-60").setAttribute("stop-color", `rgba(${er},${eg},${eb},${echoA})`);
			document.getElementById("echo-stop-80").setAttribute("stop-color", `rgba(${ar},${ag},${ab},${echoB})`);
			document.getElementById("echo-stop-100").setAttribute("stop-color", `rgba(${er},${eg},${eb},0)`);
		}
		applyGradientTheme();

		const sweepGroup = document.getElementById("sweep-group");
		const sweepTrail = document.getElementById("sweep-trail");
		const ping1 = document.getElementById("ping-1");
		const ping2 = document.getElementById("ping-2");
		const echoGroup = document.getElementById("echo-group");
		const CX = 200;
		const CY = 200;
		const R = 180;

		// Coordinate ticker — cycles through real city coordinates
		const coordLat = document.getElementById("coord-lat");
		const coordLon = document.getElementById("coord-lon");
		const locations = [
			{ lat: 51.0504, latD: "N", lon: 7.1491, lonD: "E" },   // Bergisch Gladbach
			{ lat: 48.8566, latD: "N", lon: 2.3522, lonD: "E" },   // Paris
			{ lat: 35.6762, latD: "N", lon: 139.6503, lonD: "E" },  // Tokyo
			{ lat: 40.7128, latD: "N", lon: 74.0060, lonD: "W" },   // New York
			{ lat: 55.7558, latD: "N", lon: 37.6173, lonD: "E" },   // Moscow
			{ lat: 33.8688, latD: "S", lon: 151.2093, lonD: "E" },  // Sydney
			{ lat: 52.5200, latD: "N", lon: 13.4050, lonD: "E" },   // Berlin
			{ lat: 64.1466, latD: "N", lon: 21.9426, lonD: "W" },   // Reykjavik
			{ lat: 1.3521, latD: "N", lon: 103.8198, lonD: "E" },   // Singapore
			{ lat: 37.5665, latD: "N", lon: 126.9780, lonD: "E" },  // Seoul
		];

		let coordFrom = locations[0];
		let coordTo = locations[1];
		let coordIdx = 1;
		let coordProgress = 0;
		const HOLD_TIME = 3;    // seconds to hold before scrolling
		const SCROLL_TIME = 1.2; // seconds to animate between coordinates
		let coordTimer = 0;
		let coordPhase = "hold"; // "hold" or "scroll"

		function updateCoords(dt) {
			coordTimer += dt;

			if (coordPhase === "hold") {
				if (coordTimer >= HOLD_TIME) {
					coordTimer = 0;
					coordPhase = "scroll";
					coordFrom = locations[coordIdx];
					coordIdx = (coordIdx + 1) % locations.length;
					coordTo = locations[coordIdx];
				}
			} else {
				coordProgress = Math.min(coordTimer / SCROLL_TIME, 1);
				// Smooth ease in-out
				const t = coordProgress < 0.5
					? 4 * coordProgress * coordProgress * coordProgress
					: 1 - Math.pow(-2 * coordProgress + 2, 3) / 2;

				const lat = coordFrom.lat + (coordTo.lat - coordFrom.lat) * t;
				const lon = coordFrom.lon + (coordTo.lon - coordFrom.lon) * t;
				const latD = t > 0.5 ? coordTo.latD : coordFrom.latD;
				const lonD = t > 0.5 ? coordTo.lonD : coordFrom.lonD;

				coordLat.textContent = `${lat.toFixed(4)}° ${latD}`;
				coordLon.textContent = `${Math.abs(lon).toFixed(4)}° ${lonD}`;

				if (coordProgress >= 1) {
					coordTimer = 0;
					coordPhase = "hold";
				}
			}
		}

		// Neon Wackelkontakt — only "FORECAST" flickers
		const neonEl = document.getElementById("neon-flicker");
		let neonTimer = 0;
		let nextFlicker = 2 + Math.random() * 4;

		function updateNeon(dt) {
			neonTimer += dt;
			if (neonTimer < nextFlicker) return;

			const pattern = [];
			// 2-6 rapid flickers per burst, irregular
			const flickerCount = 2 + Math.floor(Math.random() * 5);

			let t = 0;
			for (let i = 0; i < flickerCount; i++) {
				// Randomize: sometimes off, sometimes dim, varying durations
				const roll = Math.random();
				const state = roll < 0.6 ? "flicker-off" : "flicker-dim";
				const offDuration = 20 + Math.random() * 70;
				const onDuration = 15 + Math.random() * 80;

				pattern.push({ time: t, state });
				t += offDuration;

				// Sometimes double-tap: brief on then off again
				if (Math.random() < 0.3) {
					pattern.push({ time: t, state: "" });
					t += 15 + Math.random() * 30;
					pattern.push({ time: t, state: "flicker-off" });
					t += 20 + Math.random() * 40;
				}

				pattern.push({ time: t, state: "" });
				t += onDuration;
			}

			for (const step of pattern) {
				setTimeout(() => {
					neonEl.classList.remove("flicker-off", "flicker-dim");
					if (step.state) neonEl.classList.add(step.state);
				}, step.time);
			}

			neonTimer = 0;
			nextFlicker = 2 + Math.random() * 6; // every 2-8s
		}

		// Generate random doppler echo blobs (weather cells)
		const [er, eg, eb] = echoColor;
		const echoes = [];
		for (let i = 0; i < 5; i++) {
			const echoAngle = Math.random() * 360;
			const echoDist = 50 + Math.random() * 120;
			const echoR = 8 + Math.random() * 18;
			const rad = (echoAngle * Math.PI) / 180;
			const ex = CX + echoDist * Math.cos(rad);
			const ey = CY + echoDist * Math.sin(rad);
			const circle = document.createElementNS("http://www.w3.org/2000/svg", "circle");
			circle.setAttribute("cx", String(ex));
			circle.setAttribute("cy", String(ey));
			circle.setAttribute("r", String(echoR));
			const baseOp = isDay ? (0.04 + Math.random() * 0.05) : (0.02 + Math.random() * 0.04);
			circle.setAttribute("fill", `rgba(${er},${eg},${eb},${baseOp})`);
			circle.setAttribute("filter", "url(#glow)");
			echoGroup.appendChild(circle);
			echoes.push({ angle: echoAngle, el: circle, baseOpacity: baseOp });
		}
		echoGroup.setAttribute("opacity", "1");

		let lastTime = 0;
		let angle = 0;

		function animateRadar(timestamp) {
			const dt = lastTime ? (timestamp - lastTime) / 1000 : 0.016;
			lastTime = timestamp;

			// Coordinate ticker + neon flicker
			updateCoords(dt);
			updateNeon(dt);

			// ~12 seconds per full revolution
			angle = (angle + dt * 30) % 360;

			// Rotate sweep
			sweepGroup.setAttribute("transform", `rotate(${angle}, ${CX}, ${CY})`);

			// Trail cone: 35° arc
			const trailDeg = 35;
			const startRad = (-trailDeg * Math.PI) / 180;
			const x1 = CX + R * Math.cos(startRad);
			const y1 = CY + R * Math.sin(startRad);
			const x2 = CX + R;
			const y2 = CY;
			sweepTrail.setAttribute("d", `M${CX},${CY} L${x1},${y1} A${R},${R} 0 0,1 ${x2},${y2} Z`);

			// Doppler echoes: brighten when sweep passes, then fade
			for (const echo of echoes) {
				let diff = ((angle - echo.angle) % 360 + 360) % 360;
				let brightness;
				if (diff < 30) {
					brightness = echo.baseOpacity + (isDay ? 0.14 : 0.08) * (1 - diff / 30);
				} else {
					const fade = Math.min((diff - 30) / 300, 1);
					brightness = echo.baseOpacity * (1 - fade * 0.6);
				}
				echo.el.setAttribute("fill", `rgba(${er},${eg},${eb},${brightness})`);
			}

			// Ping pulses with cubic ease-out
			const p1 = (angle % 360) / 360;
			const p2 = ((angle + 180) % 360) / 360;
			const ease = (t) => 1 - Math.pow(1 - t, 3);

			ping1.setAttribute("r", String(3 + ease(p1) * 80));
			ping1.setAttribute("stroke-opacity", String(0.35 * Math.pow(1 - p1, 2)));

			ping2.setAttribute("r", String(3 + ease(p2) * 80));
			ping2.setAttribute("stroke-opacity", String(0.35 * Math.pow(1 - p2, 2)));

			requestAnimationFrame(animateRadar);
		}

		requestAnimationFrame(animateRadar);

		// Form submit
		document.getElementById("submit-btn").addEventListener("click", async () => {
			const lat = document.getElementById("lat").value;
			const lon = document.getElementById("lon").value;
			const other = document.getElementById("city").value;

			const res = await fetch("/api/set-location", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ lat, lon, other }),
			});

			if (!res.ok) {
				alert("Fehler beim Speichern der Position");
				return;
			}

			if (document.documentElement.requestFullscreen) {
				await document.documentElement.requestFullscreen();
			}

			window.location.href = "/";
		});
	</script>
</Layout>
