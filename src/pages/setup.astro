---
import Layout from "@/layouts/Layout.astro";
import { IconArrowRight, IconRadar2 } from "@tabler/icons-react";

// Precompute outer tick marks (every 30°)
const ticks = [...Array(12)].map((_, i) => {
	const a = (i * 30 * Math.PI) / 180;
	const r1 = 178;
	const r2 = 188;
	return {
		x1: 200 + r1 * Math.sin(a),
		y1: 200 - r1 * Math.cos(a),
		x2: 200 + r2 * Math.sin(a),
		y2: 200 - r2 * Math.cos(a),
	};
});

// Small ticks every 10° (skip 30° positions)
const smallTicks = [...Array(36)]
	.map((_, i) => {
		if (i % 3 === 0) return null;
		const a = (i * 10 * Math.PI) / 180;
		const r1 = 181;
		const r2 = 186;
		return {
			x1: 200 + r1 * Math.sin(a),
			y1: 200 - r1 * Math.cos(a),
			x2: 200 + r2 * Math.sin(a),
			y2: 200 - r2 * Math.cos(a),
		};
	})
	.filter(Boolean);
---

<Layout>
	<main class="h-screen w-full overflow-hidden flex" id="setup-main">
		<!-- Left: Doppler radar display -->
		<div class="relative flex-1 overflow-hidden flex items-center justify-center">
			<!-- Day mode: warm ambient glow behind radar -->
			<div id="radar-glow" class="absolute rounded-full pointer-events-none" style="width:420px;height:420px;"></div>
			<!-- Doppler Radar SVG — with integrated Da Vinci geometric construction -->
			<svg viewBox="-15 -5 430 415" class="w-95 h-95" font-family="ui-monospace, monospace">
				<defs>
					<filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
						<feGaussianBlur stdDeviation="3" result="blur"/>
						<feMerge>
							<feMergeNode in="blur"/>
							<feMergeNode in="SourceGraphic"/>
						</feMerge>
					</filter>
					<filter id="geo-glow" x="-20%" y="-20%" width="140%" height="140%">
						<feGaussianBlur stdDeviation="1.2" result="blur"/>
						<feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
					</filter>
					<linearGradient id="sweepGrad" x1="0%" y1="0%" x2="100%" y2="0%">
						<stop id="sweep-stop-0" offset="0%" stop-color="rgba(56,189,168,0.45)"/>
						<stop id="sweep-stop-1" offset="100%" stop-color="rgba(56,189,168,0.03)"/>
					</linearGradient>
					<radialGradient id="echoGrad" cx="50%" cy="50%" r="50%">
						<stop id="echo-stop-0" offset="0%" stop-color="rgba(56,189,168,0)"/>
						<stop id="echo-stop-40" offset="40%" stop-color="rgba(56,189,168,0)"/>
						<stop id="echo-stop-60" offset="60%" stop-color="rgba(56,189,168,0.06)"/>
						<stop id="echo-stop-80" offset="80%" stop-color="rgba(45,160,200,0.04)"/>
						<stop id="echo-stop-100" offset="100%" stop-color="rgba(56,189,168,0)"/>
					</radialGradient>
					<clipPath id="wave-clip">
						<rect x="-15" y="360" width="430" height="55"/>
					</clipPath>
				</defs>

				<!-- ═══════════════════════════════════════════════ -->
				<!-- LAYER 0: GEOMETRIC CONSTRUCTION (behind radar) -->
				<!-- ═══════════════════════════════════════════════ -->

				<!-- Ecliptic ring — Earth's 23.4° tilt, very slow rotation -->
				<g class="sg-ecliptic">
					<animateTransform attributeName="transform" type="rotate" from="0 200 200" to="360 200 200" dur="300s" repeatCount="indefinite"/>
					<ellipse cx="200" cy="200" rx="196" ry="118" fill="none" stroke-width="0.4" transform="rotate(23.4,200,200)"/>
					<!-- Equinox / solstice markers -->
					<circle cx="396" cy="200" r="2" fill="none" stroke-width="0.5" transform="rotate(23.4,200,200)"/>
					<circle cx="4" cy="200" r="2" fill="none" stroke-width="0.5" transform="rotate(23.4,200,200)"/>
					<circle cx="200" cy="82" r="2" fill="none" stroke-width="0.5" transform="rotate(23.4,200,200)"/>
					<circle cx="200" cy="318" r="2" fill="none" stroke-width="0.5" transform="rotate(23.4,200,200)"/>
				</g>

				<!-- Solar rays — 12 hours of Ra, slow counter-rotation behind radar rings -->
				<g class="sg-solar-ray">
					<animateTransform attributeName="transform" type="rotate" from="0 200 200" to="360 200 200" dur="360s" repeatCount="indefinite"/>
					<line x1="200" y1="172" x2="200" y2="30"  stroke-width="0.25"/>
					<line x1="200" y1="172" x2="200" y2="30"  stroke-width="0.25" transform="rotate(30,200,200)"/>
					<line x1="200" y1="172" x2="200" y2="30"  stroke-width="0.25" transform="rotate(60,200,200)"/>
					<line x1="200" y1="172" x2="200" y2="30"  stroke-width="0.25" transform="rotate(90,200,200)"/>
					<line x1="200" y1="172" x2="200" y2="30"  stroke-width="0.25" transform="rotate(120,200,200)"/>
					<line x1="200" y1="172" x2="200" y2="30"  stroke-width="0.25" transform="rotate(150,200,200)"/>
					<line x1="200" y1="172" x2="200" y2="30"  stroke-width="0.25" transform="rotate(180,200,200)"/>
					<line x1="200" y1="172" x2="200" y2="30"  stroke-width="0.25" transform="rotate(210,200,200)"/>
					<line x1="200" y1="172" x2="200" y2="30"  stroke-width="0.25" transform="rotate(240,200,200)"/>
					<line x1="200" y1="172" x2="200" y2="30"  stroke-width="0.25" transform="rotate(270,200,200)"/>
					<line x1="200" y1="172" x2="200" y2="30"  stroke-width="0.25" transform="rotate(300,200,200)"/>
					<line x1="200" y1="172" x2="200" y2="30"  stroke-width="0.25" transform="rotate(330,200,200)"/>
					<!-- Dashed interstitial rays at 15° -->
					<line x1="200" y1="165" x2="200" y2="60" stroke-width="0.15" stroke-dasharray="2 4" transform="rotate(15,200,200)"/>
					<line x1="200" y1="165" x2="200" y2="60" stroke-width="0.15" stroke-dasharray="2 4" transform="rotate(45,200,200)"/>
					<line x1="200" y1="165" x2="200" y2="60" stroke-width="0.15" stroke-dasharray="2 4" transform="rotate(75,200,200)"/>
					<line x1="200" y1="165" x2="200" y2="60" stroke-width="0.15" stroke-dasharray="2 4" transform="rotate(105,200,200)"/>
					<line x1="200" y1="165" x2="200" y2="60" stroke-width="0.15" stroke-dasharray="2 4" transform="rotate(135,200,200)"/>
					<line x1="200" y1="165" x2="200" y2="60" stroke-width="0.15" stroke-dasharray="2 4" transform="rotate(165,200,200)"/>
					<line x1="200" y1="165" x2="200" y2="60" stroke-width="0.15" stroke-dasharray="2 4" transform="rotate(195,200,200)"/>
					<line x1="200" y1="165" x2="200" y2="60" stroke-width="0.15" stroke-dasharray="2 4" transform="rotate(225,200,200)"/>
					<line x1="200" y1="165" x2="200" y2="60" stroke-width="0.15" stroke-dasharray="2 4" transform="rotate(255,200,200)"/>
					<line x1="200" y1="165" x2="200" y2="60" stroke-width="0.15" stroke-dasharray="2 4" transform="rotate(285,200,200)"/>
					<line x1="200" y1="165" x2="200" y2="60" stroke-width="0.15" stroke-dasharray="2 4" transform="rotate(315,200,200)"/>
					<line x1="200" y1="165" x2="200" y2="60" stroke-width="0.15" stroke-dasharray="2 4" transform="rotate(345,200,200)"/>
				</g>

				<!-- Flower of Life — inscribed inside the 85km ring, counter-rotating -->
				<g class="sg-flower-group">
					<animateTransform attributeName="transform" type="rotate" from="0 200 200" to="-360 200 200" dur="240s" repeatCount="indefinite"/>
					<!-- Hexagon frame -->
					<polygon points="200,160 234.6,180 234.6,220 200,240 165.4,220 165.4,180" fill="none" class="sg-hexagon" stroke-width="0.35"/>
					<!-- 6 petals -->
					<circle cx="200" cy="160" r="40" fill="none" class="sg-flower" stroke-width="0.25" stroke-dasharray="2.5 4">
						<animate attributeName="stroke-dashoffset" from="0" to="251" dur="40s" repeatCount="indefinite"/>
					</circle>
					<circle cx="234.6" cy="180" r="40" fill="none" class="sg-flower" stroke-width="0.25" stroke-dasharray="2.5 4">
						<animate attributeName="stroke-dashoffset" from="0" to="251" dur="40s" repeatCount="indefinite"/>
					</circle>
					<circle cx="234.6" cy="220" r="40" fill="none" class="sg-flower" stroke-width="0.25" stroke-dasharray="2.5 4">
						<animate attributeName="stroke-dashoffset" from="0" to="251" dur="40s" repeatCount="indefinite"/>
					</circle>
					<circle cx="200" cy="240" r="40" fill="none" class="sg-flower" stroke-width="0.25" stroke-dasharray="2.5 4">
						<animate attributeName="stroke-dashoffset" from="0" to="251" dur="40s" repeatCount="indefinite"/>
					</circle>
					<circle cx="165.4" cy="220" r="40" fill="none" class="sg-flower" stroke-width="0.25" stroke-dasharray="2.5 4">
						<animate attributeName="stroke-dashoffset" from="0" to="251" dur="40s" repeatCount="indefinite"/>
					</circle>
					<circle cx="165.4" cy="180" r="40" fill="none" class="sg-flower" stroke-width="0.25" stroke-dasharray="2.5 4">
						<animate attributeName="stroke-dashoffset" from="0" to="251" dur="40s" repeatCount="indefinite"/>
					</circle>
					<!-- Center binding circle -->
					<circle cx="200" cy="200" r="40" fill="none" class="sg-flower-center" stroke-width="0.3"/>
				</g>

				<!-- Pentagram — inscribed in the 130km ring, slow counter-rotation -->
				<g class="sg-pentagram-group">
					<animateTransform attributeName="transform" type="rotate" from="0 200 200" to="-360 200 200" dur="200s" repeatCount="indefinite"/>
					<!-- 10-pointed star (pentagram) -->
