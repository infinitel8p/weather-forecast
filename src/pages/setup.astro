					<!-- Inner pentagon -->
					<polygon points="200,70 310,148 264,273 136,273 90,148" fill="none" class="sg-pentagon" stroke-width="0.25"/>
				</g>

				<!-- Vesica piscis at center — sacred intersection -->
				<path d="M 175 200 A 50 50 0 0 1 225 200 A 50 50 0 0 1 175 200" fill="none" class="sg-vesica" stroke-width="0.35" stroke-dasharray="2 3">
					<animate attributeName="stroke-dashoffset" from="0" to="20" dur="16s" repeatCount="indefinite"/>
				</path>
				<path d="M 175 200 A 50 50 0 0 0 225 200 A 50 50 0 0 0 175 200" fill="none" class="sg-vesica" stroke-width="0.35" stroke-dasharray="2 3">
					<animate attributeName="stroke-dashoffset" from="0" to="-20" dur="16s" repeatCount="indefinite"/>
				</path>

				<!-- Golden spiral — logarithmic curve from center outward -->
				<path d="M 200 200 A 5 5 0 0 1 205 200 A 8 8 0 0 1 197 208 A 13 13 0 0 1 187 195 A 21 21 0 0 1 205 179 A 34 34 0 0 1 238 206 A 55 55 0 0 1 187 260" fill="none" class="sg-spiral" stroke-width="0.3" stroke-dasharray="2.5 4">
					<animate attributeName="stroke-dashoffset" from="0" to="280" dur="35s" repeatCount="indefinite"/>
				</path>

				<!-- ═══════════════════════════════════════════════ -->
				<!-- LAYER 1: ORIGINAL RADAR ELEMENTS ───────────── -->
				<!-- ═══════════════════════════════════════════════ -->

				<!-- Static doppler echo (faint weather pattern) -->
				<circle cx="200" cy="200" r="180" fill="url(#echoGrad)"/>

				<!-- Outer tick marks every 30° -->
				{ticks.map((t) => (
					<line x1={t.x1} y1={t.y1} x2={t.x2} y2={t.y2} class="svg-tick-major" stroke-width="0.8"/>
				))}
				<!-- Small ticks every 10° -->
				{smallTicks.map((t) => (
					<line x1={t.x1} y1={t.y1} x2={t.x2} y2={t.y2} class="svg-tick-minor" stroke-width="0.5"/>
				))}

				<!-- Micro ticks every 5° — premium density ring -->
				<g class="sg-tick-micro" stroke-width="0.3">
					<g transform="rotate(5,200,200)">  <line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(15,200,200)"> <line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(25,200,200)"> <line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(35,200,200)"> <line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(45,200,200)"> <line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(55,200,200)"> <line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(65,200,200)"> <line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(75,200,200)"> <line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(85,200,200)"> <line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(95,200,200)"> <line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(105,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(115,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(125,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(135,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(145,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(155,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(165,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(175,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(185,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(195,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(205,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(215,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(225,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(235,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(245,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(255,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(265,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(275,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(285,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(295,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(305,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(315,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(325,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(335,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(345,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
					<g transform="rotate(355,200,200)"><line x1="200" y1="17" x2="200" y2="22"/></g>
				</g>

				<!-- Range rings -->
				<circle cx="200" cy="200" r="40" fill="none" class="svg-ring" stroke-width="0.5"/>
				<circle cx="200" cy="200" r="85" fill="none" class="svg-ring-mid" stroke-width="0.5"/>
				<circle cx="200" cy="200" r="130" fill="none" class="svg-ring-far" stroke-width="0.5"/>
				<circle cx="200" cy="200" r="180" fill="none" class="svg-ring-outer" stroke-width="0.5" stroke-dasharray="2 4"/>

				<!-- Crosshairs -->
				<line x1="15" y1="200" x2="385" y2="200" class="svg-crosshair" stroke-width="0.5"/>
				<line x1="200" y1="15" x2="200" y2="385" class="svg-crosshair" stroke-width="0.5"/>
				<!-- 30°/60° diagonal crosshairs -->
				<line x1="200" y1="200" x2="44" y2="110"  class="sg-radial" stroke-width="0.3"/>
				<line x1="200" y1="200" x2="356" y2="110" class="sg-radial" stroke-width="0.3"/>
				<line x1="200" y1="200" x2="44" y2="290"  class="sg-radial" stroke-width="0.3"/>
				<line x1="200" y1="200" x2="356" y2="290" class="sg-radial" stroke-width="0.3"/>

				<!-- Range intersection ticks -->
				<line x1="113" y1="198" x2="113" y2="202" class="svg-intersection" stroke-width="0.5"/>
				<line x1="287" y1="198" x2="287" y2="202" class="svg-intersection" stroke-width="0.5"/>
				<line x1="198" y1="113" x2="202" y2="113" class="svg-intersection" stroke-width="0.5"/>
				<line x1="198" y1="287" x2="202" y2="287" class="svg-intersection" stroke-width="0.5"/>

				<!-- Golden ratio proportion marks on axes -->
				<line x1="76" y1="197" x2="76" y2="203" class="sg-prop-tick" stroke-width="0.5"/>
				<line x1="324" y1="197" x2="324" y2="203" class="sg-prop-tick" stroke-width="0.5"/>
				<line x1="197" y1="76" x2="203" y2="76" class="sg-prop-tick" stroke-width="0.5"/>
				<line x1="197" y1="324" x2="203" y2="324" class="sg-prop-tick" stroke-width="0.5"/>
				<text x="76" y="193" text-anchor="middle" class="sg-label" font-size="4">φ</text>
				<text x="324" y="193" text-anchor="middle" class="sg-label" font-size="4">φ</text>

				<!-- Compass arcs — quadrant construction -->
				<path d="M 20 200 A 180 180 0 0 1 200 20"  fill="none" class="sg-arc" stroke-width="0.4"/>
				<path d="M 380 200 A 180 180 0 0 0 200 20"  fill="none" class="sg-arc" stroke-width="0.4"/>
				<path d="M 20 200 A 180 180 0 0 0 200 380" fill="none" class="sg-arc" stroke-width="0.4"/>
				<path d="M 380 200 A 180 180 0 0 1 200 380" fill="none" class="sg-arc" stroke-width="0.4"/>

				<!-- Compass rose arrows at cardinal points -->
				<g class="sg-compass-rose">
					<path d="M 200 172 L 196 182 L 200 178 L 204 182 Z" fill="none" stroke-width="0.4"/>
					<path d="M 200 228 L 196 218 L 200 222 L 204 218 Z" fill="none" stroke-width="0.4"/>
					<path d="M 228 200 L 218 196 L 222 200 L 218 204 Z" fill="none" stroke-width="0.4"/>
					<path d="M 172 200 L 182 196 L 178 200 L 182 204 Z" fill="none" stroke-width="0.4"/>
				</g>

				<!-- Doppler echoes (revealed by sweep, animated via JS) -->
				<g id="echo-group" opacity="0"></g>

				<!-- Sweep arm + trail -->
				<g id="sweep-group">
					<path id="sweep-trail" d="" class="svg-sweep-trail"/>
					<line id="sweep-line" x1="200" y1="200" x2="380" y2="200" stroke="url(#sweepGrad)" stroke-width="1"/>
				</g>

				<!-- Ping rings -->
				<circle id="ping-1" cx="200" cy="200" r="3" fill="none" class="svg-ping" stroke-width="0.5"/>
				<circle id="ping-2" cx="200" cy="200" r="3" fill="none" class="svg-ping" stroke-width="0.5"/>

				<!-- ═══════════════════════════════════════════════ -->
				<!-- LAYER 2: TOP ELEMENTS (above sweep) ─────────── -->
				<!-- ═══════════════════════════════════════════════ -->

				<!-- Solar disk at center — pulsing Eye of Ra, behind station dot -->
				<circle cx="200" cy="200" r="16" fill="none" class="sg-solar-disk" stroke-width="0.5" filter="url(#geo-glow)">
					<animate attributeName="r" values="16;17.5;16" dur="8s" repeatCount="indefinite"/>
				</circle>
				<circle cx="200" cy="200" r="8" fill="none" class="sg-solar-disk" stroke-width="0.3">
					<animate attributeName="r" values="8;9;8" dur="8s" repeatCount="indefinite"/>
				</circle>

				<!-- Station dot with glow -->
				<circle id="station-dot" cx="200" cy="200" r="2.5" filter="url(#glow)"/>

