---
import Layout from "@/layouts/Layout.astro";
import SingleWeatherCard from "@/components/SingleWeatherCard.astro";
import WeatherChart from "@/components/WeatherChart.jsx";
import {
	IconSunrise,
	IconSunset,
	IconWind,
	IconDroplet,
	IconGauge,
	IconUvIndex,
	IconEye,
	IconCloud,
} from "@tabler/icons-react";

const env = import.meta.env;
const latCookie = Astro.cookies.get("lat");
const lonCookie = Astro.cookies.get("lon");
const cityCookie = Astro.cookies.get("city");

const lat = latCookie?.value;
const lon = lonCookie?.value;
const city = cityCookie?.value;

if (!lat || !lon) {
	return Astro.redirect("/setup");
}

let apiError = null;

const res = await fetch(
	`https://api.openweathermap.org/data/3.0/onecall?lat=${lat}&lon=${lon}&lang=DE&units=metric&exclude=minutely,alerts&appid=${env.OPENWEATHERMAPONECALL_API_KEY}`
);
const oneCall = await res.json();
if (!res.ok) apiError = oneCall.message || `API error ${res.status}`;

const time = new Date();
const currentDate = time.toLocaleDateString("de-DE", {
	timeZone: "Europe/Berlin",
	weekday: "long",
	month: "long",
	day: "numeric",
	hour: "2-digit",
	minute: "2-digit",
	hour12: false,
});

const hourlyChartLabels = oneCall.hourly?.map((h) => formatToBerlinTime(h.dt)) ?? [];
const hourlyTemperatures = oneCall.hourly?.map((h) => Math.round(h.temp)) ?? [];
const hourlyPrecipitation = oneCall.hourly?.map((h) => h.rain?.["1h"] ?? 0) ?? [];
const hourlyUVIndex = oneCall.hourly?.map((h) => Math.round(h.uvi ?? 0)) ?? [];

function formatToBerlinTime(unixTimestamp) {
	const date = new Date(unixTimestamp * 1000);
	return date.toLocaleTimeString("de-DE", {
		timeZone: "Europe/Berlin",
		hour: "2-digit",
		minute: "2-digit",
		hour12: false,
	});
}

function formatToBerlinDate(unixTimestamp) {
	const date = new Date(unixTimestamp * 1000);
	return date.toLocaleDateString("de-DE", {
		timeZone: "Europe/Berlin",
		weekday: "short",
	});
}

---

<Layout>
	<main id="dashboard-main" class="flex flex-col h-screen w-screen overflow-hidden p-2 gap-1.5 relative">
		<!-- Da Vinci-inspired geometric construction — celestial, oceanic & mythological -->
		<svg class="absolute inset-0 w-full h-full pointer-events-none davinci-geo" viewBox="0 0 800 480" preserveAspectRatio="xMidYMid slice" style="z-index: 0;" font-family="ui-monospace, monospace">
			<defs>
				<!-- Subtle glow for celestial elements -->
				<filter id="geo-glow" x="-20%" y="-20%" width="140%" height="140%">
					<feGaussianBlur stdDeviation="1.5" result="blur"/>
					<feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
				</filter>
				<!-- Wave clip to keep ocean contained -->
				<clipPath id="wave-clip">
					<rect x="0" y="380" width="800" height="100"/>
				</clipPath>
			</defs>

			<!-- ═══════════════════════════════════════════ -->
			<!-- ── I. CELESTIAL CONSTRUCTION GRID ──────── -->
			<!-- ═══════════════════════════════════════════ -->

			<!-- Primary axes — thin, precise -->
			<line x1="400" y1="8" x2="400" y2="472" class="geo-axis" stroke-width="0.35"/>
			<line x1="20" y1="240" x2="780" y2="240" class="geo-axis" stroke-width="0.35"/>

			<!-- 45° diagonals -->
			<line x1="60" y1="20" x2="740" y2="460" class="geo-diagonal" stroke-width="0.3"/>
			<line x1="740" y1="20" x2="60" y2="460" class="geo-diagonal" stroke-width="0.3"/>

			<!-- 30°/60° radials from center — star-chart construction -->
			<line x1="400" y1="240" x2="54" y2="40"   class="geo-radial" stroke-width="0.25"/>
			<line x1="400" y1="240" x2="746" y2="40"   class="geo-radial" stroke-width="0.25"/>
			<line x1="400" y1="240" x2="54" y2="440"  class="geo-radial" stroke-width="0.25"/>
			<line x1="400" y1="240" x2="746" y2="440" class="geo-radial" stroke-width="0.25"/>
			<!-- 15°/75° finer radials -->
			<line x1="400" y1="240" x2="146" y2="14"  class="geo-radial" stroke-width="0.2" stroke-dasharray="4 8"/>
			<line x1="400" y1="240" x2="654" y2="14"  class="geo-radial" stroke-width="0.2" stroke-dasharray="4 8"/>
			<line x1="400" y1="240" x2="146" y2="466" class="geo-radial" stroke-width="0.2" stroke-dasharray="4 8"/>
			<line x1="400" y1="240" x2="654" y2="466" class="geo-radial" stroke-width="0.2" stroke-dasharray="4 8"/>

			<!-- ═══════════════════════════════════════════ -->
			<!-- ── II. ARMILLARY SPHERE — PLANETARY ORBITS  -->
			<!-- ═══════════════════════════════════════════ -->

			<!-- Ecliptic ring — tilted 23.4° like Earth's axial tilt, slow rotation -->
			<g class="geo-ecliptic">
				<animateTransform attributeName="transform" type="rotate" from="0 400 240" to="360 400 240" dur="300s" repeatCount="indefinite"/>
				<ellipse cx="400" cy="240" rx="218" ry="130" fill="none" stroke-width="0.5" transform="rotate(23.4,400,240)"/>
				<!-- Equinox / solstice markers on the ecliptic -->
				<circle cx="618" cy="240" r="2.5" fill="none" stroke-width="0.6" transform="rotate(23.4,400,240)"/>
				<circle cx="182" cy="240" r="2.5" fill="none" stroke-width="0.6" transform="rotate(23.4,400,240)"/>
				<circle cx="400" cy="110" r="2.5" fill="none" stroke-width="0.6" transform="rotate(23.4,400,240)"/>
				<circle cx="400" cy="370" r="2.5" fill="none" stroke-width="0.6" transform="rotate(23.4,400,240)"/>
			</g>

			<!-- Outer celestial ring — astrolabe bezel with degree ticks -->
			<g id="geo-astrolabe">
				<animateTransform attributeName="transform" type="rotate" from="0 400 240" to="360 400 240" dur="180s" repeatCount="indefinite"/>
				<circle cx="400" cy="240" r="210" fill="none" class="geo-circle-outer" stroke-width="0.6"/>
				<!-- Major ticks every 30° -->
				<g class="geo-degree-major" stroke-width="0.9">
					<g transform="rotate(0,400,240)">  <line x1="400" y1="30"  x2="400" y2="48"/></g>
					<g transform="rotate(30,400,240)"> <line x1="400" y1="30"  x2="400" y2="48"/></g>
					<g transform="rotate(60,400,240)"> <line x1="400" y1="30"  x2="400" y2="48"/></g>
					<g transform="rotate(90,400,240)"> <line x1="400" y1="30"  x2="400" y2="48"/></g>
					<g transform="rotate(120,400,240)"><line x1="400" y1="30"  x2="400" y2="48"/></g>
					<g transform="rotate(150,400,240)"><line x1="400" y1="30"  x2="400" y2="48"/></g>
					<g transform="rotate(180,400,240)"><line x1="400" y1="30"  x2="400" y2="48"/></g>
					<g transform="rotate(210,400,240)"><line x1="400" y1="30"  x2="400" y2="48"/></g>
					<g transform="rotate(240,400,240)"><line x1="400" y1="30"  x2="400" y2="48"/></g>
					<g transform="rotate(270,400,240)"><line x1="400" y1="30"  x2="400" y2="48"/></g>
					<g transform="rotate(300,400,240)"><line x1="400" y1="30"  x2="400" y2="48"/></g>
					<g transform="rotate(330,400,240)"><line x1="400" y1="30"  x2="400" y2="48"/></g>
				</g>
				<!-- Minor ticks every 10° -->
				<g class="geo-degree-minor" stroke-width="0.4">
					<g transform="rotate(10,400,240)"> <line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(20,400,240)"> <line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(40,400,240)"> <line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(50,400,240)"> <line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(70,400,240)"> <line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(80,400,240)"> <line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(100,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(110,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(130,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(140,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(160,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(170,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(190,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(200,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(220,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(230,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(250,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(260,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(280,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(290,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(310,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(320,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(340,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
					<g transform="rotate(350,400,240)"><line x1="400" y1="30" x2="400" y2="40"/></g>
				</g>
				<!-- Micro ticks every 5° for premium density -->
				<g class="geo-degree-micro" stroke-width="0.25">
					<g transform="rotate(5,400,240)">  <line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(15,400,240)"> <line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(25,400,240)"> <line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(35,400,240)"> <line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(45,400,240)"> <line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(55,400,240)"> <line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(65,400,240)"> <line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(75,400,240)"> <line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(85,400,240)"> <line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(95,400,240)"> <line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(105,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(115,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(125,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(135,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(145,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(155,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(165,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(175,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(185,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(195,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(205,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(215,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(225,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(235,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(245,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(255,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(265,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(275,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(285,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(295,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(305,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(315,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(325,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(335,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(345,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
					<g transform="rotate(355,400,240)"><line x1="400" y1="30" x2="400" y2="36"/></g>
				</g>
			</g>

			<!-- Cardinal direction labels — compass rose style -->
			<g class="geo-label geo-cardinal" font-size="7" text-anchor="middle" font-weight="600" letter-spacing="1">
				<text x="400" y="22">N</text>
				<text x="622" y="244">E</text>
				<text x="400" y="462">S</text>
				<text x="178" y="244">W</text>
			</g>
			<!-- Degree labels -->
			<g class="geo-label" font-size="5" text-anchor="middle">
				<text x="506"  y="50">30°</text>
				<text x="580"  y="130">60°</text>
				<text x="580"  y="354">120°</text>
				<text x="506"  y="434">150°</text>
				<text x="293"  y="434">210°</text>
				<text x="218"  y="354">240°</text>
				<text x="218"  y="130">300°</text>
				<text x="293"  y="50">330°</text>
			</g>

			<!-- ═══════════════════════════════════════════ -->
			<!-- ── III. SACRED GEOMETRY — HEXAGONAL GRID ── -->
			<!-- ═══════════════════════════════════════════ -->

			<!-- Hexagonal Flower of Life pattern — counter-rotating -->
			<g id="geo-flower-of-life">
				<animateTransform attributeName="transform" type="rotate" from="0 400 240" to="-360 400 240" dur="240s" repeatCount="indefinite"/>
				<!-- Central hexagon -->
				<polygon points="400,180 452,210 452,270 400,300 348,270 348,210" fill="none" class="geo-hexagon" stroke-width="0.5"/>
				<!-- Inner Flower of Life — 6 overlapping circles -->
				<circle cx="400" cy="180" r="60" fill="none" class="geo-flower" stroke-width="0.35" stroke-dasharray="3 5">
					<animate attributeName="stroke-dashoffset" from="0" to="377" dur="40s" repeatCount="indefinite"/>
				</circle>
				<circle cx="452" cy="210" r="60" fill="none" class="geo-flower" stroke-width="0.35" stroke-dasharray="3 5">
					<animate attributeName="stroke-dashoffset" from="0" to="377" dur="40s" repeatCount="indefinite"/>
				</circle>
				<circle cx="452" cy="270" r="60" fill="none" class="geo-flower" stroke-width="0.35" stroke-dasharray="3 5">
					<animate attributeName="stroke-dashoffset" from="0" to="377" dur="40s" repeatCount="indefinite"/>
				</circle>
				<circle cx="400" cy="300" r="60" fill="none" class="geo-flower" stroke-width="0.35" stroke-dasharray="3 5">
					<animate attributeName="stroke-dashoffset" from="0" to="377" dur="40s" repeatCount="indefinite"/>
				</circle>
				<circle cx="348" cy="270" r="60" fill="none" class="geo-flower" stroke-width="0.35" stroke-dasharray="3 5">
					<animate attributeName="stroke-dashoffset" from="0" to="377" dur="40s" repeatCount="indefinite"/>
				</circle>
				<circle cx="348" cy="210" r="60" fill="none" class="geo-flower" stroke-width="0.35" stroke-dasharray="3 5">
					<animate attributeName="stroke-dashoffset" from="0" to="377" dur="40s" repeatCount="indefinite"/>
				</circle>
				<!-- Central binding circle -->
				<circle cx="400" cy="240" r="60" fill="none" class="geo-flower-center" stroke-width="0.45"/>
			</g>

			<!-- ═══════════════════════════════════════════ -->
			<!-- ── IV. INNER RINGS & PENTAGRAM ──────────── -->
			<!-- ═══════════════════════════════════════════ -->

			<!-- Mid orbital ring with pentagram — Pythagorean sacred form -->
			<g id="geo-pentagram-ring">
				<animateTransform attributeName="transform" type="rotate" from="0 400 240" to="-360 400 240" dur="200s" repeatCount="indefinite"/>
				<circle cx="400" cy="240" r="140" fill="none" class="geo-circle-mid" stroke-width="0.55"/>
				<!-- Pentagram — the golden ratio made visible -->
				<polygon points="400,100 453,200 540,200 468,260 492,360 400,300 308,360 332,260 260,200 347,200" fill="none" class="geo-star" stroke-width="0.4" stroke-linejoin="round"/>
				<!-- Inner pentagon -->
				<polygon points="400,100 540,200 492,360 308,360 260,200" fill="none" class="geo-pentagon" stroke-width="0.35"/>
			</g>

			<!-- Dashed inner rings — breathing animation -->
			<circle cx="400" cy="240" r="90" fill="none" class="geo-circle-inner" stroke-width="0.5" stroke-dasharray="4 6">
				<animate attributeName="stroke-dashoffset" from="0" to="565" dur="45s" repeatCount="indefinite"/>
			</circle>
			<circle cx="400" cy="240" r="48" fill="none" class="geo-circle-inner" stroke-width="0.35" stroke-dasharray="2 4">
				<animate attributeName="stroke-dashoffset" from="0" to="-301" dur="30s" repeatCount="indefinite"/>
			</circle>

			<!-- Vesica piscis — sacred intersection -->
			<path d="M 362 240 A 76 76 0 0 1 438 240 A 76 76 0 0 1 362 240" fill="none" class="geo-vesica" stroke-width="0.45" stroke-dasharray="2.5 3.5">
				<animate attributeName="stroke-dashoffset" from="0" to="24" dur="16s" repeatCount="indefinite"/>
			</path>
			<path d="M 362 240 A 76 76 0 0 0 438 240 A 76 76 0 0 0 362 240" fill="none" class="geo-vesica" stroke-width="0.45" stroke-dasharray="2.5 3.5">
				<animate attributeName="stroke-dashoffset" from="0" to="-24" dur="16s" repeatCount="indefinite"/>
			</path>

			<!-- ═══════════════════════════════════════════ -->
			<!-- ── V. EGYPTIAN SOLAR DISK — RA'S EYE ───── -->
			<!-- ═══════════════════════════════════════════ -->

			<!-- Solar corona rays — radiating from center, slow pulse -->
			<g class="geo-solar-ray">
				<animateTransform attributeName="transform" type="rotate" from="0 400 240" to="360 400 240" dur="360s" repeatCount="indefinite"/>
				<!-- 12 rays at 30° intervals — hours of the Egyptian day -->
				<line x1="400" y1="210" x2="400" y2="70"  stroke-width="0.3"/>
				<line x1="400" y1="210" x2="400" y2="70"  stroke-width="0.3" transform="rotate(30,400,240)"/>
				<line x1="400" y1="210" x2="400" y2="70"  stroke-width="0.3" transform="rotate(60,400,240)"/>
				<line x1="400" y1="210" x2="400" y2="70"  stroke-width="0.3" transform="rotate(90,400,240)"/>
				<line x1="400" y1="210" x2="400" y2="70"  stroke-width="0.3" transform="rotate(120,400,240)"/>
				<line x1="400" y1="210" x2="400" y2="70"  stroke-width="0.3" transform="rotate(150,400,240)"/>
				<line x1="400" y1="210" x2="400" y2="70"  stroke-width="0.3" transform="rotate(180,400,240)"/>
				<line x1="400" y1="210" x2="400" y2="70"  stroke-width="0.3" transform="rotate(210,400,240)"/>
				<line x1="400" y1="210" x2="400" y2="70"  stroke-width="0.3" transform="rotate(240,400,240)"/>
				<line x1="400" y1="210" x2="400" y2="70"  stroke-width="0.3" transform="rotate(270,400,240)"/>
				<line x1="400" y1="210" x2="400" y2="70"  stroke-width="0.3" transform="rotate(300,400,240)"/>
				<line x1="400" y1="210" x2="400" y2="70"  stroke-width="0.3" transform="rotate(330,400,240)"/>
				<!-- Alternating shorter rays at 15° for density -->
				<line x1="400" y1="200" x2="400" y2="110" stroke-width="0.2" stroke-dasharray="2 4" transform="rotate(15,400,240)"/>
				<line x1="400" y1="200" x2="400" y2="110" stroke-width="0.2" stroke-dasharray="2 4" transform="rotate(45,400,240)"/>
				<line x1="400" y1="200" x2="400" y2="110" stroke-width="0.2" stroke-dasharray="2 4" transform="rotate(75,400,240)"/>
				<line x1="400" y1="200" x2="400" y2="110" stroke-width="0.2" stroke-dasharray="2 4" transform="rotate(105,400,240)"/>
