---
import Layout from "@/layouts/Layout.astro";
import SingleWeatherCard from "@/components/SingleWeatherCard.astro";
import WeatherChart from "@/components/WeatherChart.jsx";
import {
	IconSunrise,
	IconSunset,
	IconWind,
	IconDroplet,
	IconGauge,
	IconUvIndex,
	IconEye,
	IconCloud,
} from "@tabler/icons-react";

const env = import.meta.env;
const latCookie = Astro.cookies.get("lat");
const lonCookie = Astro.cookies.get("lon");
const cityCookie = Astro.cookies.get("city");

const lat = latCookie?.value;
const lon = lonCookie?.value;
const city = cityCookie?.value;

if (!lat || !lon) {
	return Astro.redirect("/setup");
}

let res = await fetch(
	`https://api.openweathermap.org/data/2.5/weather?lat=${lat}&lon=${lon}&lang=DE&units=metric&appid=${env.OPENWEATHERMAP_API_KEY}`
);
const currentWeather = await res.json();

const time = new Date();
const currentDate = time.toLocaleDateString("de-DE", {
	timeZone: "Europe/Berlin",
	weekday: "long",
	month: "long",
	day: "numeric",
	hour: "2-digit",
	minute: "2-digit",
	hour12: false,
});

res = await fetch(
	`https://api.openweathermap.org/data/3.0/onecall?lat=${lat}&lon=${lon}&cnt=8&lang=DE&units=metric&exclude=current,minutely,hourly,alerts&appid=${env.OPENWEATHERMAPONECALL_API_KEY}`
);
const weeklyWeather = await res.json();

res = await fetch(
	`https://api.openweathermap.org/data/3.0/onecall?lat=${lat}&lon=${lon}&cnt=8&lang=DE&units=metric&exclude=current,minutely,daily,alerts&appid=${env.OPENWEATHERMAPONECALL_API_KEY}`
);
const hourlyWeather = await res.json();

const hourlyChartLabels = hourlyWeather.hourly.map((h) =>
	formatToBerlinTime(h.dt)
);
const hourlyTemperatures = hourlyWeather.hourly.map((h) => Math.round(h.temp));
const hourlyPrecipitation = hourlyWeather.hourly.map((h) => {
	if (h.rain) {
		return h.rain["1h"];
	} else {
		return 0;
	}
});

let oneCall;
try {
	res = await fetch(
		`https://api.openweathermap.org/data/2.5/onecall?lat=${lat}&lon=${lon}&units=metric&appid=${env.OPENWEATHERMAPONECALL_API_KEY}`
	);
	oneCall = await res.json();
} catch (error) {
	const fs = await import("fs/promises");
	const data = await fs.readFile("src/assets/output.json", "utf-8");
	oneCall = JSON.parse(data);
}

const hourlyUVIndex = oneCall.hourly.slice(1, 25).map((h) => {
	if (h.uvi) {
		return Math.round(h.uvi);
	} else {
		return 0;
	}
});

function formatToBerlinTime(unixTimestamp) {
	const date = new Date(unixTimestamp * 1000);
	return date.toLocaleTimeString("de-DE", {
		timeZone: "Europe/Berlin",
		hour: "2-digit",
		minute: "2-digit",
		hour12: false,
	});
}

function formatToBerlinDate(unixTimestamp) {
	const date = new Date(unixTimestamp * 1000);
	return date.toLocaleDateString("de-DE", {
		timeZone: "Europe/Berlin",
		weekday: "short",
	});
}

function meterToKm(m) {
	return m / 1000;
}
---

<Layout>
	<main id="dashboard-main" class="flex flex-col h-screen w-screen overflow-hidden p-2 gap-1.5 relative">
		<!-- Sonar background -->
		<svg id="sonar-bg" class="absolute inset-0 w-full h-full pointer-events-none" preserveAspectRatio="none" style="z-index: 0; opacity: 0.04;">
			<defs>
				<radialGradient id="sweep-fade" cx="0" cy="1" r="1">
					<stop id="sweep-fade-start" offset="0%" stop-color="rgb(56,189,168)" stop-opacity="0.3" />
					<stop id="sweep-fade-end" offset="100%" stop-color="rgb(56,189,168)" stop-opacity="0" />
				</radialGradient>
			</defs>
			<!-- Concentric rings from bottom-left -->
			<g id="sonar-rings"></g>
			<!-- Radial grid lines from bottom-left -->
			<g id="sonar-radials"></g>
			<!-- Horizontal scan lines -->
			<g id="sonar-scanlines"></g>
			<!-- Sweep arm -->
			<line id="sweep-arm" x1="0" x2="0" y1="0" y2="0" stroke="rgb(56,189,168)" stroke-width="1.5" opacity="0.5" />
			<!-- Sweep glow trail -->
			<path id="sweep-trail" fill="url(#sweep-fade)" opacity="0.3" />
		</svg>

		<!-- Top row -->
		<div class="flex gap-1.5 shrink-0" style="height: 40%;">
			<!-- Left: Current weather -->
			<div class="hud-card flex-1 flex flex-col p-3 relative overflow-hidden">
				<!-- Header -->
				<div class="flex items-baseline justify-between">
					<div>
						<div class="text-xl font-semibold dash-primary">{city ? city : currentWeather.name}</div>
						<div class="font-mono text-[11px] dash-faint">{currentDate}</div>
					</div>
					<div class="font-mono text-md dash-secondary">
						{Math.round(weeklyWeather.daily[0].temp.min)}° <span class="dash-faintest">/</span> {Math.round(weeklyWeather.daily[0].temp.max)}°
					</div>
				</div>
				<!-- Center: icon + temp -->
				<div class="flex items-center justify-center flex-1 -mt-6">
					<img
						class="w-32 h-32 object-contain weather-icon-shadow -mr-2 mt-2"
						src=`https://openweathermap.org/img/wn/${currentWeather.weather[0].icon}@4x.png`
					/>
					<div class="flex flex-col items-start">
						<p class="text-8xl font-bold font-mono dash-primary leading-none temp-glow">
							{Math.round(currentWeather.main.temp)}°
						</p>
						<p class="font-mono text-sm dash-muted -mt-2">
							Gefühlt {Math.round(currentWeather.main.feels_like)}°
						</p>
					</div>
				</div>
				<!-- Footer: description -->
				<p class="text-base font-medium dash-secondary text-center -mt-3">
					{currentWeather.weather[0].description}
				</p>
			</div>

			<!-- Right: Details grid -->
			<div class="hud-card flex-1 grid grid-cols-2 grid-rows-4 gap-x-2 gap-y-0 px-3 py-2 items-center justify-items-center">
				<div class="detail-item">
					<IconSunrise size={32} className="detail-icon" />
					<div class="detail-text">
						<span class="detail-label">Aufgang</span>
						<span class="detail-value">{formatToBerlinTime(currentWeather.sys.sunrise)}</span>
					</div>
				</div>
				<div class="detail-item">
					<IconSunset size={32} className="detail-icon" />
					<div class="detail-text">
						<span class="detail-label">Untergang</span>
						<span class="detail-value">{formatToBerlinTime(currentWeather.sys.sunset)}</span>
					</div>
				</div>
				<div class="detail-item">
					<IconWind size={32} className="detail-icon" />
					<div class="detail-text">
						<span class="detail-label">Wind</span>
						<span class="detail-value">{currentWeather.wind.speed}<span class="detail-unit">m/s</span></span>
					</div>
				</div>
				<div class="detail-item">
					<IconDroplet size={32} className="detail-icon" />
					<div class="detail-text">
						<span class="detail-label">Feuchte</span>
						<span class="detail-value">{currentWeather.main.humidity}<span class="detail-unit">%</span></span>
					</div>
				</div>
				<div class="detail-item">
					<IconGauge size={32} className="detail-icon" />
					<div class="detail-text">
						<span class="detail-label">Druck</span>
						<span class="detail-value">{currentWeather.main.pressure}<span class="detail-unit">hPa</span></span>
					</div>
				</div>
				<div class="detail-item">
					<IconUvIndex size={32} className="detail-icon" />
					<div class="detail-text">
						<span class="detail-label">UV</span>
						<span class:list={[
							"detail-value",
							{
								"!text-red-500": oneCall.current.uvi >= 11,
								"!text-red-400": oneCall.current.uvi >= 8 && oneCall.current.uvi < 11,
								"!text-orange-400": oneCall.current.uvi >= 6 && oneCall.current.uvi < 8,
								"!text-yellow-400": oneCall.current.uvi >= 3 && oneCall.current.uvi < 6,
							},
						]}>{Math.round(oneCall.current.uvi)}</span>
					</div>
				</div>
				<div class="detail-item">
					<IconEye size={32} className="detail-icon" />
					<div class="detail-text">
						<span class="detail-label">Sicht</span>
						<span class="detail-value">{meterToKm(currentWeather.visibility)}<span class="detail-unit">km</span></span>
					</div>
				</div>
				<div class="detail-item">
					<IconCloud size={32} className="detail-icon" />
					<div class="detail-text">
						<span class="detail-label">Wolken</span>
						<span class="detail-value">{currentWeather.clouds.all}<span class="detail-unit">%</span></span>
					</div>
				</div>
			</div>
		</div>

		<!-- Chart -->
		<div class="hud-card flex-1 min-h-0 px-2 py-1">
			<WeatherChart
				client:load
				labels={hourlyChartLabels}
				temperatureData={hourlyTemperatures}
				precipitationData={hourlyPrecipitation}
				uviData={hourlyUVIndex}
				sunrise={formatToBerlinTime(currentWeather.sys.sunrise)}
				sunset={formatToBerlinTime(currentWeather.sys.sunset)}
			/>
		</div>

		<!-- Weekly forecast -->
		<div class="hud-card flex justify-between items-center px-3 py-3 shrink-0 gap-2">
			{
				weeklyWeather.daily
					.slice(1)
					.map((item) => (
						<SingleWeatherCard
							title={formatToBerlinDate(item.dt)}
							temperature={Math.round(item.temp.day)}
							icon={item.weather[0].icon}
						/>
					))
			}
		</div>

		<span id="countdown" class="absolute left-2.5 bottom-1.5 font-mono text-[9px] dash-muted">
			20:00
		</span>

		<script>
			// Theme detection (day 06:00–21:59, night 22:00–05:59)
			const dashMain = document.getElementById("dashboard-main");
			const hour = new Date().getHours();
			const isDay = hour >= 6 && hour <= 21;
			dashMain.setAttribute("data-theme", isDay ? "day" : "night");

			const sonarColor = isDay ? "rgb(180,95,30)" : "rgb(56,189,168)";

			// Update sonar gradient
			document.getElementById("sweep-fade-start").setAttribute("stop-color", sonarColor);
			document.getElementById("sweep-fade-end").setAttribute("stop-color", sonarColor);
			document.getElementById("sweep-arm").setAttribute("stroke", sonarColor);

			// Countdown
			let seconds = 1200;
			const countdownEl = document.getElementById("countdown");
			function updateCountdown() {
				const min = Math.floor(seconds / 60);
				const sec = seconds % 60;
				countdownEl.textContent = `${min}:${sec.toString().padStart(2, "0")}`;
			}
			updateCountdown();
			const interval = setInterval(() => {
				seconds--;
				updateCountdown();
				if (seconds <= 0) {
					clearInterval(interval);
					window.location.reload();
				}
			}, 1000);

			// Sonar background
			const svgEl = document.getElementById("sonar-bg");
			const sweepArm = document.getElementById("sweep-arm");
			const sweepTrail = document.getElementById("sweep-trail");
			const ringsG = document.getElementById("sonar-rings");
			const radialsG = document.getElementById("sonar-radials");
			const scanlinesG = document.getElementById("sonar-scanlines");

			function buildSonar() {
				const w = svgEl.clientWidth;
				const h = svgEl.clientHeight;
				const ns = "http://www.w3.org/2000/svg";

				// Clear previous
				ringsG.innerHTML = "";
				radialsG.innerHTML = "";
				scanlinesG.innerHTML = "";

				// Rings from bottom-left
				const ringSpacing = 100;
				const maxR = Math.sqrt(w * w + h * h);
				for (let r = ringSpacing; r < maxR; r += ringSpacing) {
					const c = document.createElementNS(ns, "circle");
					c.setAttribute("cx", 0);
					c.setAttribute("cy", h);
					c.setAttribute("r", r);
					c.setAttribute("fill", "none");
					c.setAttribute("stroke", sonarColor);
					c.setAttribute("stroke-width", "0.5");
					ringsG.appendChild(c);
				}

				// Radial lines every 15° from bottom-left (0-90° quadrant)
				for (let a = 15; a < 90; a += 15) {
					const rad = (a * Math.PI) / 180;
					const l = document.createElementNS(ns, "line");
					l.setAttribute("x1", 0);
					l.setAttribute("y1", h);
					l.setAttribute("x2", Math.cos(rad) * maxR);
					l.setAttribute("y2", h - Math.sin(rad) * maxR);
					l.setAttribute("stroke", sonarColor);
					l.setAttribute("stroke-width", "0.3");
					l.setAttribute("stroke-dasharray", "2 6");
					radialsG.appendChild(l);
				}

				// Horizontal scan lines
				for (let y = 0.2; y < 1; y += 0.2) {
					const l = document.createElementNS(ns, "line");
					l.setAttribute("x1", 0);
					l.setAttribute("y1", h * y);
					l.setAttribute("x2", w);
					l.setAttribute("y2", h * y);
					l.setAttribute("stroke", sonarColor);
					l.setAttribute("stroke-width", "0.3");
					l.setAttribute("stroke-dasharray", "3 10");
					scanlinesG.appendChild(l);
				}
			}
			buildSonar();

			// Sweep animation
			let sweepAngle = 0;
			let lastTime = performance.now();
			const SWEEP_SPEED = 12;
			const TRAIL_DEG = 30;

			function animateSweep(now) {
				const dt = (now - lastTime) / 1000;
				lastTime = now;
				sweepAngle = (sweepAngle + SWEEP_SPEED * dt) % 90;

				const h = svgEl.clientHeight;
				const len = Math.sqrt(svgEl.clientWidth ** 2 + h ** 2);
				const rad = (sweepAngle * Math.PI) / 180;

				// Arm
				sweepArm.setAttribute("x1", 0);
				sweepArm.setAttribute("y1", h);
				sweepArm.setAttribute("x2", Math.cos(rad) * len);
				sweepArm.setAttribute("y2", h - Math.sin(rad) * len);

				// Trail arc
				const trailStart = Math.max(0, sweepAngle - TRAIL_DEG);
				const r1 = (trailStart * Math.PI) / 180;
				const r2 = rad;
				const arcR = len * 0.6;
				const x1 = Math.cos(r1) * arcR;
				const y1 = h - Math.sin(r1) * arcR;
				const x2 = Math.cos(r2) * arcR;
				const y2 = h - Math.sin(r2) * arcR;
				sweepTrail.setAttribute("d",
					`M 0 ${h} L ${x1} ${y1} A ${arcR} ${arcR} 0 0 1 ${x2} ${y2} Z`
				);

				requestAnimationFrame(animateSweep);
			}
			requestAnimationFrame(animateSweep);
		</script>
	</main>
</Layout>

<style is:global>
	/* ── Theme custom properties ── */
	#dashboard-main {
		--accent: 56, 189, 168;
		--accent-warm: 56, 189, 168;
		--accent-copper: 45, 160, 200;
		--bg-main: #050d12;
		--card-bg: rgba(10, 18, 25, 0.7);
		--card-border: rgba(56, 189, 168, 0.06);
		--text-primary: rgba(204, 251, 241, 0.9);
		--text-secondary: rgba(204, 251, 241, 0.5);
		--text-muted: rgba(56, 189, 168, 0.25);
		--text-faint: rgba(56, 189, 168, 0.2);
		--text-faintest: rgba(56, 189, 168, 0.12);
		--icon-color: rgba(56, 189, 168, 0.2);
		--icon-shadow: drop-shadow(0 0 12px rgba(56, 189, 168, 0.08));
		--temp-shadow: 0 0 25px rgba(56, 189, 168, 0.06);
		background: var(--bg-main);
		transition: background 0.6s ease;
	}

	#dashboard-main[data-theme="day"] {
		--accent: 110, 78, 30;
		--accent-warm: 200, 140, 30;
		--accent-copper: 180, 95, 30;
		--bg-main: #e8e0d4;
		--card-bg: rgba(243, 238, 228, 0.8);
		--card-border: rgba(180, 95, 30, 0.1);
		--text-primary: rgba(50, 35, 15, 0.92);
		--text-secondary: rgba(50, 35, 15, 0.55);
		--text-muted: rgba(110, 78, 30, 0.4);
		--text-faint: rgba(110, 78, 30, 0.25);
		--text-faintest: rgba(110, 78, 30, 0.2);
		--icon-color: rgba(200, 140, 30, 0.3);
		--icon-shadow: drop-shadow(0 0 8px rgba(200, 140, 30, 0.1));
		--temp-shadow: 0 0 20px rgba(200, 140, 30, 0.06);
		background: linear-gradient(145deg, #e8e1d5, #e5dccf);
	}

	/* ── Text utilities ── */
	.dash-primary { color: var(--text-primary); transition: color 0.6s ease; }
	.dash-secondary { color: var(--text-secondary); transition: color 0.6s ease; }
	.dash-muted { color: var(--text-muted); transition: color 0.6s ease; }
	.dash-faint { color: var(--text-faint); transition: color 0.6s ease; }
	.dash-faintest { color: var(--text-faintest); transition: color 0.6s ease; }

	.temp-glow { text-shadow: var(--temp-shadow); }
	.weather-icon-shadow { filter: var(--icon-shadow); }

	/* ── Cards ── */
	.hud-card {
		background: var(--card-bg);
		border: 1px solid var(--card-border);
		border-radius: 6px;
		position: relative;
		z-index: 1;
		transition: background 0.6s ease, border-color 0.6s ease;
	}
	#dashboard-main[data-theme="day"] .hud-card {
		box-shadow: 0 1px 6px rgba(110, 78, 30, 0.05);
	}

	/* ── Detail items ── */
	.detail-item {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.detail-icon {
		color: var(--icon-color);
		flex-shrink: 0;
		transition: color 0.6s ease;
	}
	.detail-text {
		display: flex;
		flex-direction: column;
	}
	.detail-label {
		font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
		font-size: 11px;
		color: rgba(var(--accent), 0.22);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		line-height: 1;
		transition: color 0.6s ease;
	}
	#dashboard-main[data-theme="day"] .detail-label {
		color: rgba(var(--accent-copper), 0.45);
	}
	.detail-value {
		font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
		font-size: 22px;
		font-weight: 700;
		color: var(--text-primary);
		line-height: 1.2;
		transition: color 0.6s ease;
	}
	.detail-unit {
		font-size: 11px;
		font-weight: 500;
		color: rgba(var(--accent), 0.25);
		margin-left: 1px;
		transition: color 0.6s ease;
	}
	#dashboard-main[data-theme="day"] .detail-unit {
		color: rgba(var(--accent-copper), 0.4);
	}

	/* ── Weekly card (SingleWeatherCard) ── */
	.weekly-label {
		color: rgba(var(--accent), 0.3);
		transition: color 0.6s ease;
	}
	#dashboard-main[data-theme="day"] .weekly-label {
		color: rgba(var(--accent-copper), 0.45);
	}
	.weekly-temp {
		color: var(--text-primary);
		transition: color 0.6s ease;
	}
	.weekly-icon-shadow {
		filter: drop-shadow(0 0 5px rgba(var(--accent), 0.06));
		transition: filter 0.6s ease;
	}
	#dashboard-main[data-theme="day"] .weekly-icon-shadow {
		filter: drop-shadow(0 0 5px rgba(var(--accent-warm), 0.08));
	}
</style>
