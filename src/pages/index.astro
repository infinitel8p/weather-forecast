			<path id="sweep-trail" fill="url(#sweep-fade)" opacity="0.3" />
		</svg>

		{apiError ? (
		<div class="flex-1 flex items-center justify-center">
			<div class="hud-card p-6 text-center max-w-md">
				<p class="text-2xl font-semibold dash-primary mb-2">Wetterdaten nicht verfügbar</p>
				<p class="text-sm dash-muted font-mono">{apiError}</p>
				<p class="text-xs dash-muted mt-3">Die Seite wird automatisch neu geladen.</p>
			</div>
		</div>
		) : (<Fragment>
		<!-- Top row -->
		<div class="flex gap-1.5 shrink-0" style="height: 40%;">
			<!-- Left: Current weather -->
			<div class="hud-card flex-1 flex flex-col p-3 relative overflow-hidden">
				<!-- Header -->
				<div class="flex items-baseline justify-between">
					<div>
						<div class="text-xl font-semibold dash-primary">{city ?? ""}</div>
						<div class="font-mono text-[11px] dash-muted">{currentDate}</div>
					</div>
					<div class="font-mono text-md dash-secondary">
						{Math.round(oneCall.daily[0].temp.min)}° <span class="dash-muted">/</span> {Math.round(oneCall.daily[0].temp.max)}°
					</div>
				</div>
				<!-- Center: icon + temp -->
				<div class="flex items-center justify-center flex-1 -mt-6">
					<img
						class="w-32 h-32 object-contain weather-icon-shadow -mr-2 mt-2"
						src=`https://openweathermap.org/img/wn/${oneCall.current.weather[0].icon}@4x.png`
					/>
					<div class="flex flex-col items-start">
						<p class="text-8xl font-bold font-mono dash-primary leading-none temp-glow">
							{Math.round(oneCall.current.temp)}°
						</p>
						<p class="font-mono text-sm dash-muted -mt-2">
							Gefühlt {Math.round(oneCall.current.feels_like)}°
						</p>
					</div>
				</div>
				<!-- Footer: description -->
				<p class="text-base font-medium dash-secondary text-center -mt-3">
					{oneCall.current.weather[0].description}
